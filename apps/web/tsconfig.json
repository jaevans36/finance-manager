{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@life-manager/schema": ["../../packages/schema/src/index.ts"],
      "@life-manager/schema/*": ["../../packages/schema/src/*"],
      "@life-manager/ui": ["../../packages/ui/src/index.ts"],
      "@life-manager/ui/*": ["../../packages/ui/src/*"],
      "@life-manager/ui/styles": ["../../packages/ui/src/styles/index.ts"],
      "@life-manager/ui/components": ["../../packages/ui/src/components/index.ts"],
      "@life-manager/ui/contexts": ["../../packages/ui/src/contexts/index.ts"]
    }
  },
  "include": ["src", "../../VERSION.json"],
  "exclude": ["node_modules", "dist", "tests"]
}
