# Life Manager — Production Environment Variables
# Copy this file to .env.production and fill in real values.
# .env.production is gitignored and must never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=life_manager
DB_NAME=life_manager_prod
# Choose a strong password (16+ characters, mixed case + symbols)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API JWT Secret ─────────────────────────────────────────────────────────────
# Must be 64+ characters. Generate one with PowerShell:
#   [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
JWT_SECRET=CHANGE_ME_64_CHARACTER_RANDOM_SECRET_KEY

# ── JWT Issuer / Audience ──────────────────────────────────────────────────────
# Must match the hostname used in the browser.
# For localhost access:    https://localhost
# For LAN hostname access: https://life-manager
JWT_ISSUER=https://life-manager
JWT_AUDIENCE=https://life-manager

# ── Frontend API URL ───────────────────────────────────────────────────────────
# Baked into the frontend bundle at build time.
# The API is proxied through nginx, so use just the origin (no port, no /api path).
# For same-machine access:
VITE_API_URL=https://localhost
# For LAN access from other devices using a custom hostname (e.g. after adding to hosts file):
#   VITE_API_URL=https://life-manager

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin the browser uses to reach the frontend (must match VITE_API_URL origin).
FRONTEND_ORIGIN=https://localhost
# For LAN with hostname:
#   FRONTEND_ORIGIN=https://life-manager
