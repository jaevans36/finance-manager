# Life Manager — Production Environment Variables
# Copy this file to .env.production and fill in real values.
# .env.production is gitignored and must never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=life_manager
DB_NAME=life_manager_prod
# Choose a strong password (16+ characters, mixed case + symbols)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API JWT Secret ─────────────────────────────────────────────────────────────
# Must be 64+ characters. Generate one with PowerShell:
#   [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Maximum 256 }) -as [byte[]])
JWT_SECRET=CHANGE_ME_64_CHARACTER_RANDOM_SECRET_KEY

# ── Frontend API URL ───────────────────────────────────────────────────────────
# This is baked into the frontend bundle at build time.
# Use http://localhost:5000 for same-machine browser access.
# For LAN access from other devices, use your machine's IP or hostname:
#   VITE_API_URL=http://192.168.1.100:5000
VITE_API_URL=http://localhost:5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin the browser uses to access the frontend.
# Change if you access via a hostname rather than localhost.
FRONTEND_ORIGIN=http://localhost
