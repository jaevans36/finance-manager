{
  "name": "finance-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Personal finance manager with To Do app foundation",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:api": "pnpm --filter @finance-manager/api dev",
    "dev:web": "pnpm --filter @finance-manager/web dev",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive run test",
    "lint": "pnpm --recursive run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
