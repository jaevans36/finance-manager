{
  "name": "finance-manager",
  "version": "0.15.0",
  "private": true,
  "description": "Personal finance manager with To Do app foundation",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:api": "pnpm --filter @finance-manager/api dev",
    "dev:web": "pnpm --filter @finance-manager/web dev",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive run test",
    "lint": "pnpm --recursive run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --recursive run typecheck",
    "start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "restart": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-dev.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-db.ps1",
    "db:reset-test": "powershell -ExecutionPolicy Bypass -File ./scripts/reset-test-db.ps1",
    "logs": "powershell -ExecutionPolicy Bypass -File ./scripts/view-logs.ps1",
    "test:all": "powershell -ExecutionPolicy Bypass -File ./scripts/run-tests.ps1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
